# ---- Core ----
NODE_ENV=development
PORT=8080
APP_BASE_URL=http://localhost:8080
PUBLIC_WEB_URL=https://tejotime.com
LOG_LEVEL=info
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_CURRENCY=INR
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081

# ---- Supabase ----
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Direct Postgres connection (used ONLY by the migration/seed CLI, never at runtime)
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
SUPABASE_STORAGE_BUCKET=media

# ---- Auth (generate strong random values) ----
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
CUSTOMER_TOKEN_SECRET=change-me-customer
TICKET_URL_HMAC_SECRET=change-me-ticket
PASSWORD_PEPPER=change-me-pepper
# Shared secret for the admin panel's store-provisioning API (min 16 chars).
# Use the SAME value in admin-panel/.env.local.
ADMIN_API_KEY=change-me-admin-key-min-16-chars

# ---- Plan / feature config ----
FREE_PLAN_CUSTOMER_LIMIT=2
TWO_AWAY_THRESHOLD=2
TICKET_ABANDON_HOURS=4
BOOKING_SLOT_MINUTES=30

# ---- Feature flags for deferred external integrations ----
OTP_ENABLED=false
PAYMENTS_ENABLED=false
SMS_ENABLED=false
EMAIL_ENABLED=false

# ---- OTP (used when OTP_ENABLED=true) ----
OTP_LENGTH=4
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_PEPPER=change-me-otp
